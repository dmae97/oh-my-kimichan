{
  "name": "oh-my-kimichan",
  "version": "0.4.0",
  "description": "Kimi Code CLI용 multi-agent orchestration harness. Kimi K2.6 위에 올라가는 하네스 + 팀 런타임 + 스킬/훅/워크플로 배포판",
  "type": "module",
  "bin": {
    "omk": "dist/cli.js",
    "oh-my-kimichan": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "node node_modules/eslint/bin/eslint.js --max-warnings=0 src/ && npm run secret:scan",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "audit:package": "node scripts/package-audit.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "kimi",
    "kimi-cli",
    "kimi-code",
    "kimi-k2",
    "k2.6",
    "oh-my-kimi",
    "oh-my-kimichan",
    "ai",
    "ai-agent",
    "ai-agents",
    "agent",
    "agentic-coding",
    "coding-agent",
    "developer-tools",
    "cli",
    "typescript",
    "nodejs",
    "orchestration",
    "multi-agent",
    "multi-agent-orchestration",
    "workflow-automation",
    "dag",
    "task-graph",
    "scheduler",
    "ensemble",
    "agent-ensemble",
    "worktree",
    "tmux",
    "mcp",
    "model-context-protocol",
    "lsp",
    "language-server-protocol",
    "design-md",
    "quality-gates",
    "yolo-mode",
    "local-first",
    "graph-memory",
    "neo4j"
  ],
  "author": "dmae97",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^14.0.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.0.0",
    "neo4j-driver": "^6.0.1",
    "node-pty": "^1.1.0",
    "terminal-image": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "globals": "^15.0.0",
    "tsx": "^4.0.0"
  },
  "files": [
    "dist",
    "templates",
    "kimichan.png",
    "kimiagent.png",
    "omk-hud-1.png",
    "omk-hud-screenshot.png",
    "omk-hud-dev-screenshot.png",
    "omk-statusline-gauge.png",
    "omk-statusline-reset.png",
    "README.md",
    "AGENTS.md",
    "SECURITY.md",
    "ROADMAP.md",
    "DESIGN.md",
    "WORKER_MANIFEST.md",
    "CLAUDE.md",
    "GEMINI.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmae97/oh-my-kimichan.git"
  },
  "bugs": {
    "url": "https://github.com/dmae97/oh-my-kimichan/issues"
  },
  "homepage": "https://github.com/dmae97/oh-my-kimichan#readme",
  "engines": {
    "node": ">=20.0.0"
  }
}
